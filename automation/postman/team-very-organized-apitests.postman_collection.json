              "pm.test(\"ID = 1\", () => pm.expect(pm.response.json().id).to.eql(1));\r",
              "pm.test(\"Champs requis\", () => {\r",
              "  const u = pm.response.json();\r",
              "  pm.expect(u).to.have.property(\"name\");\r",
              "  pm.expect(u).to.have.property(\"email\");\r",
