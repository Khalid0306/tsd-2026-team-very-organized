  "item": [
    {
      "name": "GET users",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));\r",
              "pm.test(\"Liste non vide\", () => {\r",
              "  pm.expect(pm.response.json().length).to.be.above(0);\r",
              "});\r",
              "pm.test(\"Premier user a un email\", () => {\r",
              "  pm.expect(pm.response.json()[0]).to.have.property(\"email\");\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users",
          "protocol": "https",
          "host": [
            "jsonplaceholder",
            "typicode",
            "com"
          ],
          "path": [
            "users"
          ]
        }
      },
      "response": []
    },
    {
